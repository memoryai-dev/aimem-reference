# aimem-reference — example environment
# Copy to .env and edit. NEVER commit .env.

# PostgreSQL connection. The reference impl needs the `vector` and
# `pg_trgm` extensions; the migration runner installs them.
DATABASE_URL=postgresql://aimem:aimem@localhost:5432/aimem

# Producer Namespace per draft §3.1 — used as `producer` envelope field
# and prefix for native chunk URNs (urn:aimem:<producer>:chunk-N).
# Lowercase ASCII, [a-z0-9-], 1-63 chars.
AIMEM_PRODUCER=aimem-reference

# Admin secret for /v1/admin/provision. Pick a long random string.
AIMEM_ADMIN_SECRET=replace-with-openssl-rand-hex-32

# Pool sizing
AIMEM_POOL_MIN=2
AIMEM_POOL_MAX=10

# Server
AIMEM_HOST=0.0.0.0
AIMEM_PORT=9420
